 * ═══════════════════════════════════════════════════════════════ */
QFrame#RoomSnapRow { background: transparent; }
QLabel#RoomSnapLabel { font-size: 13px; font-weight: 600; color: @text@; background: transparent; }
QLabel#RoomSnapCount { font-size: 13px; font-weight: 700; background: transparent; }
QLabel#AlertTitle { font-size: 13px; font-weight: 700; background: transparent; }
QLabel#AlertDetail { font-size: @font.sm@; color: @text_muted@; background: transparent; }
QLabel#TodoTitle { font-size: 13px; font-weight: 700; color: @text@; background: transparent; }
QLabel#TodoHint { font-size: @font.sm@; color: @text_muted@; background: transparent; }
QLabel#SectionCardTitle { font-size: @font.md@; font-weight: 700; color: @text@; letter-spacing: 0.3px; background: transparent; }
QLabel#WelcomeTitle { font-size: @font.lg@; font-weight: 700; color: @text@; background: transparent; }
QLabel#WelcomeDate { font-size: 13px; color: @text_muted@; background: transparent; }
QLabel#WelcomeShift { font-size: @font.sm@; color: @text_muted@; background: transparent; }
QLabel#WelcomeOperator { font-size: @font.sm@; font-weight: 600; color: @primary@; background: transparent; }
QLabel#RoomTotalLabel { font-size: 13px; font-weight: 600; color: @text_muted@; background: transparent; }
QLabel#RoomOccupancyLabel { font-size: 13px; font-weight: 700; color: @primary@; background: transparent; }
QLabel#AlertEmptyLabel { font-size: 13px; color: @text_dim@; padding: @font.lg@; background: transparent; }
QProgressBar#RoomSnapBar { border: none; border-radius: 5px; }
QProgressBar#RoomSnapBar::chunk { border-radius: 5px; }
/* ═══ v8.1 END ═══ */

/* ═══════════════════════════════════════════════════════════════
 * v8.2 房态矩阵卡片子控件 — 静态排版从 room_matrix.py refresh_style() 迁移
 * ═══════════════════════════════════════════════════════════════ */
QLabel#RoomCardId { font-size: 2@radius.md@; font-weight: 900; background: transparent; border: none; }
QLabel#RoomCardGuest { font-size: @font.md@; font-weight: 600; background: transparent; }
QLabel#RoomCardMeta { font-size: @font.sm@; background: transparent; border: none; }
QLabel#RoomCardStatus { font-size: @font.sm@; font-weight: 800; background: transparent; border: none; padding: 0; }
QLabel#RoomCardLockWarn { font-size: @font.xs@; font-weight: 800; border-radius: @radius.md@; padding: 1px @radius.sm@; }
/* ═══ v8.2 END ═══ */

/* ═══════════════════════════════════════════════════════════════
 * v8.3 房态图例 + 筛选条组件
 * ═══════════════════════════════════════════════════════════════ */
QLabel#LegendTitle { font-size: 11px; font-weight: 600; color: @text_muted@; letter-spacing: 1.2px; background: transparent; }
QLabel#LegendDot { font-size: @font.md@; background: transparent; }
QLabel#LegendLabel { font-size: @font.sm@; color: @text_muted@; background: transparent; }
/* ═══ v8.3 END ═══ */

/* ═══════════════════════════════════════════════════════════════
 * sub-c UI/UX 打磨（2026-06-22）
 *   1. .SolidCard 统一卡片样式（p-4=@font.lg@ / p-6=24px / gap-4=@font.lg@ / gap-6=24px）
 *   2. QTableWidget/QListWidget max-h-96 = 384px，长列表自动滚动
 *   3. 原生 QPushButton/QToolButton/QListWidgetItem hover 反馈 + 指针手型
 *   4. QScrollBar 悬停加粗（细条 @radius.sm@ → @radius.md@）+ 圆角
 *   5. QGroupBox/QFrame 卡片底部留 padding，避免内容贴边
 * ═══════════════════════════════════════════════════════════════ */

/* ── 1. .SolidCard 统一卡片样式（业务页可 setObjectName("SolidCard") 复用）── */
QFrame#SolidCard, QGroupBox#SolidCard {
    background-color: @surface@;
    border: 1px solid @border@;
    border-radius: @radius.md@;
    padding: @font.lg@;            /* p-4 = @font.lg@ */
}
QFrame#SolidCardLg, QGroupBox#SolidCardLg {
    background-color: @surface@;
    border: 1px solid @border@;
    border-radius: @font.sm@;
    padding: 24px;            /* p-6 = 24px */
}
/* 卡片间 gap-4 (@font.lg@) — 通过 QLayout setSpacing(16) 落地，QSS 仅兜底 */
QFrame#SolidCard + QFrame#SolidCard,
QFrame#SolidCardLg + QFrame#SolidCardLg {
    margin-top: @font.lg@;
}

/* ── 2. 长列表 max-h-96=384px（PySide6 QSS 不直接支持 max-height，靠 setMaximumHeight 落地）── */
/*    此处仅给视觉规则：交替行 / 表头加高 / 行高密度。具体限高在 style_data_table 里调 setMaximumHeight(384) */
QTableWidget#SolidLongList,
QListWidget#SolidLongList {
    background-color: @surface@;
    border: 1px solid @border@;
    border-radius: @radius.md@;
    alternate-background-color: @bg@;
    outline: 0;
    /* 触发 max-height 仍需 setMaximumHeight(384) */
}
QTableWidget#SolidLongList::item,
QListWidget#SolidLongList::item {
    padding: @radius.md@ @font.sm@;
    border-bottom: 1px solid @border@;
}
QListWidget#SolidLongList::item:selected {
    background-color: @primary@;
    color: @surface@;
}
QListWidget#SolidLongList::item:hover {
    background-color: @bg@;
}

/* ── 4. QScrollBar 悬停加粗（细条 @radius.sm@ → @radius.md@）+ 圆角 ──
 *    原 §26 滚动条样式已存在；此处覆盖以增强悬停反馈（细条变粗条更易抓） */
QScrollBar:vertical {
    width: @radius.sm@;                /* 细条 @radius.sm@ — 默认态不抢内容 */
    background-color: transparent;
    margin: 2px 0;
    border-radius: @radius.sm@;
}
QScrollBar:vertical:hover {
    width: @font.xs@;               /* 悬停加粗到 @font.xs@，方便精准拖拽 */
    background-color: @bg@;
}
QScrollBar:horizontal {
    height: @radius.sm@;
    background-color: transparent;
    margin: 0 2px;
    border-radius: @radius.sm@;
}
QScrollBar:horizontal:hover {
    height: @font.xs@;
    background-color: @bg@;
}
QScrollBar::handle:vertical,
QScrollBar::handle:horizontal {
    border-radius: @radius.sm@;
}
QScrollBar::handle:vertical:hover,
QScrollBar::handle:horizontal:hover {
    border-radius: @radius.sm@;
}

/* ── 5. QGroupBox 统一卡片间距（sub-c：卡片对齐）── */
QGroupBox {
    background-color: transparent;
    border: 1px solid @border@;
    border-radius: @radius.md@;
    margin-top: 1@radius.md@;          /* 标题预留 */
    padding: @font.lg@ @font.lg@ @font.lg@ @font.lg@;
    font-weight: 600;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 2px @font.xs@;
    margin-top: 4px;
    background-color: @bg@;
    border: 1px solid @border@;
    border-radius: @radius.sm@;
    color: @text_muted@;
    font-size: @font.sm@;
}

/* ═══ sub-c END ═══ */
