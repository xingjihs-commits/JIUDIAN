/* ═══ v7.7 P2 全站页面 UX 补全 ═══ */

/* 财务页 v7 */
QWidget#FinanceTab { background-color: @bg@; }
QFrame#FinanceSectionSep { background-color: @border@; max-height: 1px; margin: @radius.md@ 0; }
QPushButton#FinanceQuickExpenseBtn {
    background-color: @bg@; border: 1px solid @border@; border-radius: @radius.md@;
    min-height: 52px; font-weight: 600; color: @text@; padding: 0 @radius.md@;
}
QPushButton#FinanceQuickExpenseBtn:hover { background-color: @selected_bg@; border-color: @primary@; color: @primary@; }

/* 库存页 v7 */
QWidget#InventoryTab { background-color: @bg@; }
QLabel#InventorySectionTitle { font-size: @font.lg@; font-weight: 700; color: @text@; background: transparent; }
QLabel#InventoryLowWarnTitle { font-size: 13px; font-weight: 600; color: @danger@; background: transparent; }
QLabel#InventoryFilterChip { font-size: 11px; color: @text_muted@; padding: 0 4px; background: transparent; }

/* 系统设置控制台 v7 */
QWidget#SystemConsolePage { background-color: @bg@; }
QWidget#SystemConsolePage QGroupBox { background-color: @surface@; border: 1px solid @border@; border-radius: @radius.md@; }

/* 厂家控制台 v7 */
QWidget#VendorConsolePage { background-color: @bg@; }
QWidget#VendorConsolePage QGroupBox#VendorGroup {
    background-color: @surface@; border: none; border-top: 1px solid @border@; border-radius: 0;
    margin-top: @font.md@; padding: @font.lg@ 0 @radius.md@ 0; font-weight: 700;
}
QFrame#VendorStatRow { background-color: @surface@; border: 1px solid @border@; border-radius: @radius.sm@; margin: 4px 0; padding: 2px 4px; }
QLabel#VendorStatLabel { color: @text@; font-weight: 600; font-size: @font.sm@; background: transparent; }
QLabel#VendorStatValue { font-weight: 700; font-family: Consolas, monospace; background: transparent; }
QPlainTextEdit#VendorConsoleMono { background-color: @bg@; border: 1px solid @border@; border-radius: @radius.md@; font-family: Consolas, monospace; font-size: @font.sm@; }
QPlainTextEdit#VendorConsoleLog { background-color: @sidebar@; color: @text_dim@; border: none; border-top: 1px solid @border@; font-family: Consolas, monospace; font-size: 11px; }

/* 卡片系统页 v7 */
QWidget#CardSystemRoot { background-color: @bg@; }
QFrame#CardSystemHeader { background-color: @bg@; border: 1px solid @border@; border-radius: 0; padding: @radius.md@ @font.sm@; }
QFrame#MetricsRow { background-color: @bg@; border: 1px solid @border@; border-radius: 0; padding: @radius.sm@; }
QFrame#MetricCard { background-color: @surface@; border: 1px solid @border@; border-radius: @radius.md@; padding: @radius.md@ @font.md@; }
QFrame#MetricCard[highlighted="true"] { border: 2px solid @primary@; }
QFrame#MetricCard:hover { border-color: @accent@; }
QLabel#CardReadUid { font-weight: 700; color: @text_dim@; padding: @radius.md@ @font.sm@; border: 1px solid @border@; border-radius: @radius.sm@; background-color: @surface@; min-width: 180px; }
QLabel#CardReadUid[state="ok"] { color: @primary@; border-color: @primary@; }
QLabel#CardReadUid[state="error"] { color: @danger@; border-color: @danger@; }
QFrame#ActionPanel { background-color: @bg@; border: 1px solid @border@; border-radius: 0; padding: @radius.md@; min-width: 16@radius.md@; max-width: 200px; }

/* 交班 dock v7 */
QFrame#FdShiftDock { background-color: @surface@; border: 1px solid @border@; border-radius: 0; }
QFrame#FdShiftDock QPlainTextEdit#FdShiftNotes { background-color: @surface@; border: 1px solid @border@; border-radius: @radius.sm@; padding: @radius.sm@; }

/* 流水底栏 v7 */
QFrame#FrontdeskLedgerDock { background-color: @surface@; border: 1px solid @border@; border-left: 3px solid @gold_thread@; border-radius: 0; }
QFrame#FdLedgerFilterBar { background-color: @bg@; }
QFrame#FdLedgerFilterBar QPushButton#FdFilterChip { background-color: @surface@; }

/* 退房弹窗 v7 */
QDialog#CheckoutDialog { background-color: @surface@; border-radius: @font.sm@; }

/* 借物弹窗 v7 */
QDialog#BorrowDialog { background-color: @surface@; border-radius: @font.sm@; }

/* 房态矩阵房卡 v7 */
QFrame#RoomCard { background-color: @surface@; border: 1px solid @border@; border-radius: @font.xs@; }
QWidget#RoomCardBody { background: transparent; }
QLabel#RoomCardId { font-size: 22px; font-weight: 700; color: @text@; background: transparent; border: none; }
QLabel#RoomCardGuest { font-size: 13px; font-weight: 600; color: @text@; background: transparent; }
QLabel#RoomCardMeta { font-size: 11px; color: @text_muted@; background: transparent; border: none; }
QLabel#RoomCardStatus { font-size: @font.sm@; font-weight: 700; background: transparent; border: none; padding: 0; }
QLabel#RoomCardBadge { font-size: 11px; font-weight: 700; border-radius: @radius.md@; padding: 2px @font.xs@; }
QLabel#RoomCardLockWarn { background: @bg@; color: @room_reserved@; border: 1px solid @room_reserved@; border-radius: @radius.md@; padding: 1px @radius.sm@; font-size: @font.xs@; font-weight: 600; }
QLabel#RoomCardTypeIcon { font-size: @font.sm@; font-weight: 700; border-radius: @radius.md@; padding: 2px @radius.md@; }

/* 空状态 v7 */
QFrame#MatrixEmptyState { background: @surface@; border: 1px dashed @border@; border-radius: @font.sm@; }
QLabel#MatrixEmptyTitle { font-size: @font.lg@; font-weight: 600; color: @text_muted@; }
QLabel#MatrixEmptyHint { font-size: @font.sm@; color: @text_dim@; }

/* 统一设置导航树 v7 */
QTreeWidget#SettingsNavTree { background: @bg@; border: none; border-right: 1px solid @border@; outline: 0; padding: @font.xs@ 0; font-size: 13px; }
QTreeWidget#SettingsNavTree::item { padding: @radius.md@ @font.xs@; color: @text@; }
QTreeWidget#SettingsNavTree::item:has-children { color: @text_muted@; font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; padding-top: @font.sm@; padding-bottom: 4px; background: transparent; }
QTreeWidget#SettingsNavTree::item:selected { background: @selected_bg@; color: @primary@; font-weight: 700; border-radius: @radius.sm@; }
QTreeWidget#SettingsNavTree::item:hover:!selected { background: @bg@; color: @text@; border-radius: @radius.sm@; }

/* 批量操作按钮 v7 */
QPushButton#BatchPrimaryBtn { background: @primary@; color: @surface@; border: 1px solid @primary@; border-radius: @radius.md@; padding: @radius.sm@ @font.lg@; font-weight: 600; }
QPushButton#BatchSecondaryBtn { background: @bg@; color: @text_muted@; border: 1px solid @border@; border-radius: @radius.md@; padding: @radius.sm@ @font.md@; }
QPushButton#BatchSuccessBtn { background: @accent@; color: @surface@; border-radius: @radius.md@; padding: @radius.sm@ @font.md@; font-weight: 600; }
QPushButton#BatchWarnBtn { background: @room_reserved@; color: @surface@; border-radius: @radius.md@; padding: @radius.sm@ @font.md@; font-weight: 600; }

/* 制卡仪式弹窗 v7 */
QFrame#RitualHeader { background: @sidebar@; border-bottom: 1px solid @sidebar_hover@; min-height: 72px; max-height: 72px; border-top-left-radius: @font.sm@; border-top-right-radius: @font.sm@; }
QLabel#RitualHeaderIcon { color: @accent@; font-size: 22px; min-width: 32px; background: transparent; }
QLabel#RitualHeaderTitle { color: @surface@; font-size: @font.lg@; font-weight: 700; background: transparent; }
QLabel#RitualHeaderSubtitle { color: rgba(255, 255, 255, 0.45); font-size: @font.sm@; background: transparent; }
QFrame#RitualBody { background: @surface@; border-bottom-left-radius: @font.sm@; border-bottom-right-radius: @font.sm@; }
QFrame#RitualAnimationBox { background: @bg@; border: 1px solid @border@; border-radius: @font.lg@; min-height: 2@font.xl@; }
QLabel#RitualTitle { color: @text@; font-size: 1@radius.md@; font-weight: 700; padding: 4px @font.sm@; background: transparent; }
QLabel#RitualSubtitle { color: @text_muted@; font-size: 13px; padding: 2px @font.sm@; background: transparent; }
QLabel#RitualHint { color: @text_dim@; font-size: @font.sm@; padding: 2px @font.sm@; background: transparent; }
QProgressBar#RitualProgress { background: @border@; border: none; border-radius: 3px; min-height: @radius.sm@; max-height: @radius.sm@; }
QProgressBar#RitualProgress::chunk { background: @accent@; border-radius: 3px; }

/* 数据表围栏 v7 */
QFrame#DataTableShell { background: @surface@; border: 1px solid @border@; border-left: 4px solid @gold_thread@; border-radius: 0; padding: 0; }
QFrame#FdCard QFrame#DataTableShell { border-left: none; }

/* 报表 KPI v7 */
QFrame#ReportKpiCard { background: @elevated@; border: 1px solid @border@; border-top: 2px solid @accent@; border-left: 1px solid @accent@; border-right: 1px solid @accent@; border-radius: @radius.md@; padding: @radius.md@; }
QFrame#ReportKpiCard QLabel#ReportKpiTitle { color: @text_muted@; font-size: 11px; font-weight: 600; letter-spacing: 0.@radius.md@; background: transparent; }
QFrame#ReportKpiCard QLabel#ReportKpiSub { color: @text_dim@; font-size: 11px; background: transparent; }
QFrame#ReportKpiCard QLabel#ReportKpiValue { font-size: 24px; font-weight: 700; background: transparent; letter-spacing: -0.3px; }
QFrame#ReportKpiCard QLabel#ReportKpiValue[tone="primary"] { color: @primary@; }
QFrame#ReportKpiCard QLabel#ReportKpiValue[tone="amount_positive"] { color: @amount_positive@; }
QFrame#ReportKpiCard QLabel#ReportKpiValue[tone="danger"] { color: @danger@; }
QFrame#ReportKpiCard QLabel#ReportKpiValue[tone="accent"] { color: @accent@; }

/* 审计报告 v7 */
QTextEdit#NightAuditReport { background: @bg@; border: 1px solid @border@; border-radius: @radius.md@; font-family: Consolas, monospace; font-size: @font.sm@; color: @text@; }
QLabel#AuditOverviewCard { background: @surface@; color: @text@; border: 1px solid @border@; border-radius: @radius.md@; padding: @font.md@ @font.lg@; }
QLabel#AuditSafe { color: @amount_positive@; background: @bg@; border-radius: @radius.md@; padding: 4px @font.sm@; font-weight: 600; }
QLabel#AuditCaution { color: @accent@; background: @bg@; border-radius: @radius.md@; padding: 4px @font.sm@; font-weight: 600; }
QLabel#AuditDanger { color: @danger@; background: @bg@; border-radius: @radius.md@; padding: 4px @font.sm@; font-weight: 600; }

/* ═══ v7.7 P2 END ═══ */

